# Database (required for auth)
DATABASE_URL=postgresql://user:password@localhost:5432/your_database

# Auth API
PORT=3001
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
CONFIRMATION_EXPIRES_MINUTES=1440

# Frontend URL (for verification links in emails). REQUIRED in production: set to your real app URL or confirmation links will point to localhost and break.
# Local:
APP_BASE_URL=http://localhost:5173
# Production (e.g.):
# APP_BASE_URL=https://bioqz.com

# Resend (sign-up confirmation email). If unset, verification link is only logged to the server console.
# For a custom sender: in Resend dashboard verify your domain (e.g. bioqz.com), then set RESEND_FROM=e.g. "Resume AI <noreply@bioqz.com>"
# RESEND_API_KEY=re_...
# RESEND_FROM=Resume AI <onboarding@resend.dev>

# Stripe (optional – leave unset to return "Billing not configured" from upgrade/cancel)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_PRO=price_...   (Pro plan price ID)
# STRIPE_PRICE_ENTERPRISE=price_...   (Enterprise plan price ID)
# STRIPE_WEBHOOK_SECRET=whsec_...     (for saving stripe_customer_id after checkout)

# AI Resume Builder
DEEPSEEK_API_KEY=
# REDIS_URL=  # optional; job-desc cache and lockout (otherwise in-memory)

# Optional: frontend .env (Vite). Leave unset in dev (defaults to http://localhost:3001) and in production single-server (same-origin).
# VITE_API_URL=http://localhost:3001
